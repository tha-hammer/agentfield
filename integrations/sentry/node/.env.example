AGENTFIELD_NODE_ID=sentry-dev
AGENTFIELD_SERVER=http://localhost:8080
SENTRY_NODE_LISTEN=:8014
# Set this when SENTRY_NODE_LISTEN includes a host, or when the control plane
# should call the node through a tunnel/container hostname.
SENTRY_NODE_PUBLIC_URL=http://localhost:8014
SENTRY_AUTH_TOKEN=sntrys_replace_me
SENTRY_ORG=replace_me
SENTRY_CLIENT_SECRET=replace_me
