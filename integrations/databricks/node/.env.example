AGENTFIELD_SERVER=http://host.docker.internal:8080
AGENTFIELD_NODE_ID=databricks
DATABRICKS_NODE_LISTEN=:8013
DATABRICKS_NODE_PUBLIC_URL=http://localhost:8013

DATABRICKS_HOST=https://<workspace-host>
DATABRICKS_TOKEN=<workspace-token-or-oauth-bearer-token>
DATABRICKS_WAREHOUSE_ID=<sql-warehouse-id>
DATABRICKS_CATALOG=<catalog>
DATABRICKS_SCHEMA=<schema>
DATABRICKS_MAX_ROWS=100
DATABRICKS_TIMEOUT_SECONDS=30

# Optional. Used by ai_query/explain_result when the request omits endpoint.
DATABRICKS_AI_ENDPOINT=
DATABRICKS_PROMPTS_FILE=
